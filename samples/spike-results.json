            "attributes": {},
            "childNodes": [
              {
                "id": 36,
                "nodeType": 3,
                "nodeValue": "\n    const box = document.getElementById('target-box');\n    const container = document.getElementById('container');\n    const log = document.getElementById('log');\n    let childCount = 0;\n\n    document.getElementById('btn-add').addEventListener('click', () => {\n      childCount++;\n      const p = document.createElement('p');\n      p.id = `child-${childCount}`;\n      p.textContent = `Dynamic Child #${childCount}`;\n      container.appendChild(p);\n      log.textContent = `Added child #${childCount}`;\n    });\n\n    document.getElementById('btn-color').addEventListener('click', () => {\n      const colors = ['#4caf50', '#2196f3', '#9c27b0', '#ffeb3b'];\n      const randomColor = colors[Math.floor(Math.random() * colors.length)];\n      box.style.backgroundColor = randomColor;\n      log.textContent = `Changed color to ${randomColor}`;\n    });\n\n    document.getElementById('btn-remove').addEventListener('click', () => {\n      if (box && box.parentNode) {\n        box.parentNode.removeChild(box);\n        log.textContent = `Removed box`;\n      }\n    });\n\n    // Console logs for testing console observer\n    console.log(\"Page initialized\");\n    console.warn(\"This is a warning log\");\n  "
              }
